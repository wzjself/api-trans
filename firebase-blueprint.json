{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user account information, roles, and quota details.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "balance": { "type": "number", "description": "Permanent credit balance" },
        "quotaType": { "type": "string", "enum": ["none", "daily", "monthly"] },
        "dailyQuota": { "type": "number", "description": "Fixed quota per day for daily/monthly cards" },
        "quotaExpiresAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "ApiKey": {
      "title": "API Key",
      "description": "API keys generated by users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "key": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "revoked"] }
      },
      "required": ["id", "uid", "key", "status"]
    },
    "UsageLog": {
      "title": "Usage Log",
      "description": "Tracks API usage for analytics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "keyId": { "type": "string" },
        "tokens": { "type": "number" },
        "cost": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "model": { "type": "string" }
      },
      "required": ["uid", "tokens", "timestamp"]
    },
    "RedemptionCode": {
      "title": "Redemption Code",
      "description": "Codes used to top up balance or activate cards.",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "type": { "type": "string", "enum": ["permanent", "daily", "monthly"] },
        "value": { "type": "number", "description": "Amount of credit or daily quota" },
        "durationDays": { "type": "number", "description": "Duration for daily/monthly cards" },
        "isUsed": { "type": "boolean" },
        "usedBy": { "type": "string" },
        "usedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "type", "value", "isUsed"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/api_keys/{keyId}": {
      "schema": "ApiKey",
      "description": "API keys"
    },
    "/usage_logs/{logId}": {
      "schema": "UsageLog",
      "description": "Usage logs"
    },
    "/redemption_codes/{code}": {
      "schema": "RedemptionCode",
      "description": "Redemption codes"
    }
  }
}
